# ── Billhound Configuration ──────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Application ──────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=true
LOG_LEVEL=DEBUG                  # DEBUG | INFO | WARNING | ERROR

# ── Database (async PostgreSQL) ──────────────────────────────
# For docker-compose, use: postgresql+asyncpg://postgres:postgres@postgres:5432/billhound
# For local dev, use:      postgresql+asyncpg://postgres:postgres@localhost:5432/billhound
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/billhound
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ── Encryption ───────────────────────────────────────────────
# 32-byte hex-encoded AES-256 key (64 hex characters)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# ── Telegram Bot ─────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── Gmail OAuth 2.0 ──────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# ── Outlook OAuth ────────────────────────────────────────────
# Azure Portal → App registrations
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=

# ── OAuth Redirect ───────────────────────────────────────────
# Base URL for OAuth callbacks (must match registered redirect URIs)
OAUTH_REDIRECT_BASE_URL=http://localhost:8080

# ── LLM Provider ────────────────────────────────────────────
LLM_PROVIDER=openai              # openai | anthropic
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# ── Subscription Detection ───────────────────────────────────
CONFIDENCE_THRESHOLD=0.70
SCAN_INTERVAL_MINUTES=60

# ── Playwright / Automation ──────────────────────────────────
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000
SCREENSHOT_DIR=data/screenshots

# ── ACP (Virtuals Agent Commerce Protocol) ─────────────────
# Set ACP_ENABLED=true to connect to the Virtuals network as a seller agent.
# Register at https://app.virtuals.io/acp/join to get your entity ID.
ACP_ENABLED=false
ACP_WALLET_PRIVATE_KEY=         # Whitelisted wallet private key (no 0x prefix)
ACP_AGENT_WALLET_ADDRESS=       # Your agent's wallet address on Base
ACP_ENTITY_ID=                  # Entity ID from Virtuals ACP registration
